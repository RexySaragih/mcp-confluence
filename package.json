    "@modelcontextprotocol/sdk": "1.0.4",
    "marked": "^15.0.6",
    "turndown": "^7.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/turndown": "^5.0.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
